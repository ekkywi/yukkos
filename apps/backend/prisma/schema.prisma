generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  TENANT
  PROVIDER
  ADMIN
}

enum StatusListing {
  AVAILABLE
  FULL
}

enum TypeListing {
  MALE
  FEMALE
  MIXED
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(TENANT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings  Listing[]
  bookings  Booking[]
}

model Listing {
  id           String          @id @default(uuid())
  name         String
  city         String
  fullAddress  String          @db.Text
  monthlyPrice Int
  description  String          @db.Text
  type         TypeListing
  status       StatusListing   @default(AVAILABLE)
  facilities   ListingFacility[]
  bookings     Booking[]

  mainImage    String?

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  providerId   String
  provider     User            @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("listings")
}

model Facility {
  id       Int               @id @default(autoincrement())
  name     String            @unique
  listings ListingFacility[]

  @@map("facilities")
}

model ListingFacility {
  listingId  String
  facilityId Int
  
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@id([listingId, facilityId])
  @@map("listing_facilities")
}

model Booking {
  id             String        @id @default(uuid())
  listingId      String
  tenantId       String
  status         BookingStatus @default(PENDING)
  checkInDate    DateTime
  durationMonths Int
  totalPrice     Float
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  listing        Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tenant         User          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}